<!doctype html>
<html lang="it">

<head>
   <meta charset="utf-8">
   <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
   <link rel="preconnect" href="https://fonts.gstatic.com">
   <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&family=Open+Sans:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&display=swap" rel="stylesheet">
   <link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro&display=swap" rel="stylesheet">
   <link rel="stylesheet" type="text/css" href="/stylesheets/moloc.css">
   <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/sweetalert2@10.13.0/dist/sweetalert2.css">
   <link href="//netdna.bootstrapcdn.com/font-awesome/3.2.1/css/font-awesome.css" rel="stylesheet">
   <link rel='shortcut icon' type='image/x-icon' href='/images/favicon-moloc.ico' />
   <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" integrity="sha384-JcKb8q3iqJ61gNV9KGb8thSsNjpSL0n8PARn9HuZOnIxN0hoP+VmmDGMN5t9UJ0Z" crossorigin="anonymous">
   <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-select@1.13.14/dist/css/bootstrap-select.min.css">
   <title>moloc: un ambiente per modellare il lavoro collaborativo</title>
</head>

<body>
<!--Header-->
<nav class="navbar navbar-dark py-1 navtop fixed-top border-bottom border-dark shadow-lg justify-content-start">
   <a class="navbar-brand" href="/">moloc <small>v. 6.7</small></a>
   <div class="d-flex justify-content-between col-md-10 col-sm-8 ml-5">
      <select class="selectpicker" onchange="window.location.href=this.value">
         <optgroup label="Dashboard">
            <option value="/profilo_utente">Gestione Profilo</option>
         </optgroup>
         <optgroup label="Documento di analisi">
            <option value="/profilo_utente/visualizza_documento/<%=documento.id%>">Anteprima Documento</option>
            <option selected>Modifica Documento</option>
         </optgroup>
      </select>
      <ul class="nav">
         <li class="nav-item dropdown mr-5">
            <a class="nav-link dropdown-toggle utente text-right" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
               <%= utente.username %>
            </a>
            <div class="dropdown-menu utentelogin" aria-labelledby="navbarDropdown">
               <a class="dropdown-item" href="/logout">Logout</a>
            </div>
         </li>
      </ul>
   </div>
</nav>
<!--End Header-->
<!--Main content-->
<div class="container-fluid page-content" id="up">
   <form action="/profilo_utente/modifica_documento/<%=documento.id%>/crea_versione_documento" method="post">
      <div class="row">

         <nav class="col-2 sidebar px-0">
            <div class="sidebar-sticky px-0" role="tablist">
               <div class="list-group">
                  <a class="list-group-item list-group-item-action py-1 border-right-0 border-left-0 text-center" href="#titolo_documento">
                     Titolo
                  </a>
                  <a class="list-group-item list-group-item-action py-1 border-right-0 border-left-0 text-center" href="#sinossi_documento">
                     Sinossi
                  </a>
                  <a class="list-group-item list-group-item-action py-1 border-right-0 border-left-0 text-center" href="#descrizione_documento">
                     Descrizione
                  </a>
                  <a class="list-group-item list-group-item-action py-1 border-right-0 border-left-0 text-center" href="#descrizione_semplificata_documento">
                     Descrizione semplificata
                  </a>
                  <a class="list-group-item list-group-item-action py-1 border-right-0 border-left-0 text-center" href="#descrizione_ridotta_documento">
                     Descrizione ridotta
                  </a>
                  <a class="list-group-item list-group-item-action py-1 border-right-0 border-left-0 text-center" href="#descrizione_residua_documento">
                     Descrizione residua
                  </a>
                  <a class="list-group-item list-group-item-action py-1 border-right-0 border-left-0 text-center" href="#parafrasi_documento">
                     Parafrasi
                  </a>
                  <a class="list-group-item list-group-item-action py-1 border-right-0 border-left-0 text-center" href="#glossario_documento">
                     Glossario
                  </a>
                  <a class="list-group-item list-group-item-action py-1 border-right-0 border-left-0 text-center" href="#ruoli_documento">
                     Ruoli
                  </a>
                  <a class="list-group-item list-group-item-action py-1 border-right-0 border-left-0 text-center" href="#documenti_documento">
                     Documenti
                  </a>
                  <a class="list-group-item list-group-item-action py-1 border-right-0 border-left-0 text-center" href="#flussi_documento">
                     Flussi
                  </a>
                  <a class="list-group-item list-group-item-action py-1 border-right-0 border-left-0 text-center" href="#attività_documento">
                     Attività
                  </a>
                  <a class="list-group-item list-group-item-action py-1 border-right-0 border-left-0 text-center mb-5" href="#note_documento">
                     Note
                  </a>
               </div>
               <%if (!documento.flag) { %>
                  <button class="btn btn-sm btn-light col-8 offset-2 px-0 mt-4 form-restore-and-delete" type="submit">Ripristina versione</button>
                  <a href="/profilo_utente" class="btn btn-sm btn-light col-8 offset-2 px-0 mt-4" role="button">Torna indietro</a>
               <% } else{ %>
               <button class="btn btn-sm btn-light col-8 offset-2 px-0 form-save" type="submit" formmethod="post" formaction="/profilo_utente/modifica_documento/<%=documento.id%>/salva_documento">Aggiorna versione</button>
               <%if (documento.indice<1.02) { %>
                  <button class="btn btn-sm btn-light col-8 offset-2 px-0 mt-4 form-create" type="submit">Crea nuova versione</button>
               <% } else{ %>
                  <button class="btn btn-sm btn-light col-8 offset-2 px-0 mt-4 form-create-and-delete" type="submit">Crea nuova versione</button>
               <% } %>
               <a href="/profilo_utente/visualizza_documento/<%=documento.id%>" class="btn btn-sm btn-light col-8 offset-2 px-0 mt-4 form-undo" role="button">Torna indietro</a>
               <i id="info" class="icon-question-sign d-block mt-4 float-right" data-toggle="tooltip" data-html="true" data-placement="bottom" title="<p>Ogni documento ha uno storico delle versioni, fino ad un massimo di 2 versioni precedenti.</p>
              <p>Aggiornando la versione corrente sovrascriverai il documento sulla versione attuale.</p>
              <p>Se scegli di creare un'altra versione, ne verrà generata una nuova contenente il testo modificato fino a quel momento.</p>
              <p>Se hai già 2 versioni precedenti a quella attuale e scegli di crearne una nuova, ti verrà presentato un messaggio popup che chiederà la tua conferma nell'eliminare la versione meno recente.</p>"></i>
               <% } %>
            </div>
         </nav>
         <div class="col-10 content">
            <div class="section-title col-12 mx-auto py-3 border-bottom border-dark">
               <h3 id="titolo_documento" class="mt-5">Modifica il documento di analisi</h3>
            </div>
            <div class="col-11 p-0 mx-auto">
               <div class="row mt-4">
                  <div class="col-8">
                     <%if (!documento.flag || !anno.titolo) { %>
                        <textarea class="form-control tabSupport border-dark mt-4 editsection" style="color: black" name="titolo_documento" rows="1" readonly><%- documento.titolo %></textarea>
                     <% } else{ %>
                        <textarea class="form-control tabSupport border-dark mt-4 editsection" style="color: black" name="titolo_documento" rows="1"><%- documento.titolo %></textarea>
                     <% } %>
                  </div>
                  <div class="col-2 offset-1">
                     <label class="d-block"><b>Versione</b></label>
                     <select class="form-control" style="color: black" onchange="window.location.href=this.value">
                        <% versioni.forEach(function(versione){ %>
                        <%if (versione.id == documento.id) { %>
                        <option value="/profilo_utente/modifica_documento/<%=versione.id%>" selected><%=(versione.indice).toFixed(2)%></option>
                        <% } else{ %>
                        <option value="/profilo_utente/modifica_documento/<%=versione.id%>"><%=(versione.indice).toFixed(2)%></option>
                        <% } %>
                        <% }) %>
                     </select>
                  </div>
               </div>
               <p class="text-center mt-4" id="utente"><%= nickname %></p>
               <p class="text-center"><small>Ultima modifica:</small> <small id="ultima_modifica"><%= documento.ultimamodifica %></small></p>

               <br>
               <hr class="col-8 dotted" id="sinossi_documento">
               <br>

               <h4 class="mt-2 mb-4"><b>Sinossi</b></h4>
               <%if (!documento.flag || !anno.sinossi) { %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="sinossi_documento" rows="10" readonly><%- documento.sinossi %></textarea>
               <% } else{ %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="sinossi_documento" rows="10"><%- documento.sinossi %></textarea>
               <% } %>

               <br>
               <hr class="col-8 dotted" id="descrizione_documento">
               <br>

               <h4 class="mt-2 mb-4"><b>Descrizione</b></h4>
               <%if (!documento.flag || !anno.descrizione) { %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="descrizione_documento" rows="10" readonly><%- documento.descrizione %></textarea>
               <% } else{ %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="descrizione_documento" rows="10"><%- documento.descrizione %></textarea>
               <% } %>

               <br>
               <hr class="col-8 dotted" id="descrizione_semplificata_documento">
               <br>

               <h4 class="mt-2 mb-4"><b>Descrizione semplificata</b></h4>
               <%if (!documento.flag || !anno.descrizione_semplificata) { %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="descrizione_semplificata_documento" rows="10" readonly><%- documento.descrizione_semplificata %></textarea>
               <% } else{ %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="descrizione_semplificata_documento" rows="10"><%- documento.descrizione_semplificata %></textarea>
               <% } %>

               <br>
               <hr class="col-8 dotted" id="descrizione_ridotta_documento">
               <br>

               <h4 class="mt-2 mb-4"><b>Descrizione ridotta</b></h4>
               <%if (!documento.flag || !anno.descrizione_ridotta) { %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="descrizione_ridotta_documento" rows="10" readonly><%- documento.descrizione_ridotta %></textarea>
               <% } else{ %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="descrizione_ridotta_documento" rows="10"><%- documento.descrizione_ridotta %></textarea>
               <% } %>

               <br>
               <hr class="col-8 dotted" id="descrizione_residua_documento">
               <br>

               <h4 class="mt-2 mb-4"><b>Descrizione residua</b></h4>
               <%if (!documento.flag || !anno.descrizione_residua) { %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="descrizione_residua_documento" rows="10" readonly><%- documento.descrizione_residua %></textarea>
               <% } else{ %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="descrizione_residua_documento" rows="10"><%- documento.descrizione_residua %></textarea>
               <% } %>

               <br>
               <hr class="col-8 dotted" id="parafrasi_documento">
               <br>

               <h4 class="mt-2 mb-4"><b>Parafrasi</b></h4>
               <%if (!documento.flag || !anno.parafrasi) { %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="parafrasi_documento" rows="10" readonly><%- documento.parafrasi %></textarea>
               <% } else{ %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="parafrasi_documento" rows="10"><%- documento.parafrasi %></textarea>
               <% } %>

               <br>
               <hr class="col-8 dotted" id="glossario_documento">
               <br>

               <h4 class="mt-2 mb-4"><b>Glossario</b></h4>
               <%if (!documento.flag || !anno.glossario) { %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="glossario_documento" rows="6" readonly><%- documento.glossario %></textarea>
               <% } else{ %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="glossario_documento" rows="6"><%- documento.glossario %></textarea>
               <% } %>

               <br>
               <hr class="col-8 dotted" id="ruoli_documento">
               <br>

               <h4 class="mt-2 mb-4"><b>Ruoli</b></h4>
               <ul>
                  <li>
                     <b>Ruoli individuali</b>
                     <%if (!documento.flag || !anno.ruoli) { %>
                        <textarea class="form-control col-10 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="ruoli_individuali_documento" rows="6" readonly><%- documento.ruoli_individuali %></textarea>
                     <% } else{ %>
                        <textarea class="form-control col-10 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="ruoli_individuali_documento" rows="6"><%- documento.ruoli_individuali %></textarea>
                     <% } %>
                  </li>
                  <li class="mt-4">
                     <b>Ruoli collettivi</b>
                     <%if (!documento.flag || !anno.ruoli) { %>
                        <textarea class="form-control col-10 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="ruoli_collettivi_documento" rows="6" readonly><%- documento.ruoli_collettivi %></textarea>
                     <% } else{ %>
                        <textarea class="form-control col-10 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="ruoli_collettivi_documento" rows="6"><%- documento.ruoli_collettivi %></textarea>
                     <% } %>
                  </li>
                  <li class="mt-4">
                     <b>Ruoli giuridici</b>
                     <%if (!documento.flag || !anno.ruoli) { %>
                        <textarea class="form-control col-10 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="ruoli_giuridici_documento" rows="6" readonly><%- documento.ruoli_giuridici %></textarea>
                     <% } else{ %>
                        <textarea class="form-control col-10 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="ruoli_giuridici_documento" rows="6"><%- documento.ruoli_giuridici %></textarea>
                     <% } %>
                  </li>
               </ul>

               <br>
               <hr class="col-8 dotted" id="documenti_documento">
               <br>

               <h4 class="mt-2 mb-4"><b>Documenti</b></h4>
               <%if (!documento.flag || !anno.documenti) { %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="documenti_documento" rows="10" readonly><%- documento.documenti %></textarea>
               <% } else{ %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="documenti_documento" rows="10"><%- documento.documenti %></textarea>
               <% } %>

               <br>
               <hr class="col-8 dotted" id="flussi_documento">
               <br>

               <h4 class="mt-2 mb-4"><b>Flussi</b></h4>
               <%if (!documento.flag || !anno.flussi) { %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="flussi_documento" rows="10" readonly><%- documento.flussi %></textarea>
               <% } else{ %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="flussi_documento" rows="10"><%- documento.flussi %></textarea>
               <% } %>

               <br>
               <hr class="col-8 dotted" id="attività_documento">
               <br>

               <h4 class="mt-2 mb-4"><b>Attività</b></h4>
               <ul>
                  <li>
                     <b>Attività dei ruoli individuali</b>
                     <%if (!documento.flag || !anno.attivita) { %>
                        <textarea class="form-control col-10 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="attività_individuali_documento" rows="6" readonly><%- documento.attivita_ruoli_individuali %></textarea>
                     <% } else{ %>
                        <textarea class="form-control col-10 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="attività_individuali_documento" rows="6"><%- documento.attivita_ruoli_individuali %></textarea>
                     <% } %>
                  </li>
                  <li class="mt-4">
                     <b>Attività dei ruoli collettivi</b>
                     <%if (!documento.flag || !anno.attivita) { %>
                        <textarea class="form-control col-10 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="attività_collettive_documento" rows="6" readonly><%- documento.attivita_ruoli_collettivi %></textarea>
                     <% } else{ %>
                        <textarea class="form-control col-10 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="attività_collettive_documento" rows="6"><%- documento.attivita_ruoli_collettivi %></textarea>
                     <% } %>
                  </li>
                  <li class="mt-4">
                     <b>Attività dei ruoli giuridici</b>
                     <%if (!documento.flag || !anno.attivita) { %>
                        <textarea class="form-control col-10 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="attività_giuridiche_documento" rows="6" readonly><%- documento.attivita_ruoli_giuridici %></textarea>
                     <% } else{ %>
                        <textarea class="form-control col-10 mx-auto tabSupport border-dark mt-4 editsection" style="color: black" name="attività_giuridiche_documento" rows="6"><%- documento.attivita_ruoli_giuridici %></textarea>
                     <% } %>
                  </li>
               </ul>

               <br>
               <hr class="col-8 dotted" id="note_documento">
               <br>

               <h4 class="mt-2 mb-4"><b>Note</b></h4>
               <%if (!documento.flag || !anno.note) { %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection mb-4" style="color: black" name="note_documento" rows="10" readonly><%- documento.note %></textarea>
               <% } else{ %>
                  <textarea class="form-control col-11 mx-auto tabSupport border-dark mt-4 editsection mb-4" style="color: black" name="note_documento" rows="10"><%- documento.note %></textarea>
               <% } %>
            </div>

         </div>

      </div>
   </form>
</div>
<!--End main content-->
<!--Footer-->
<footer class="page-footer border-top border-dark">
   <div class="col-12 text-center text-white">
   </div>
</footer>
<!--End footer-->
<a id="back-to-top" href="#up" class="back-to-top border rounded-circle" role="button"><img alt="ScrollUp" src=/images/btt.png></a>
<script src="https://code.jquery.com/jquery-3.1.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@10.13.0"></script>
<script src="https://cdn.jsdelivr.net/gh/gitbrent/bootstrap4-toggle@3.6.1/js/bootstrap4-toggle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js" integrity="sha384-9/reFTGAW83EW2RDu2S0VKaIzap3H66lZH81PoYlFhbGU+6BZp6G7niu735Sk7lN" crossorigin="anonymous"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js" integrity="sha384-B4gt1jrGC7Jh4AgTPSdUtOBvfO8shuf57BaghqFfPlYxofvL8/KUEfYiJOMMV+rV" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap-select@1.13.14/dist/js/bootstrap-select.min.js"></script>
<script src="/javascripts/moloc.js"></script>
</body>

</html>
